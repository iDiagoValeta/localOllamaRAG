*.pt
*.bin
*.pth

# llama.cpp (clonar como submódulo o por separado)
llama.cpp/

# Binarios descargados (quantize_to_q4km.ps1)
llama-bin/

# Modelo fusionado (generado por merge_lora.py, muy pesado)
